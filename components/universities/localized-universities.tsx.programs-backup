function citySearchText(value: string | null | undefined, translation?: Translation) {
  const raw = [translation?.city, value].filter(Boolean).join(' ');
  const normalizedRaw = normalizeArabic(raw);
  const normalizedRawEn = normalize(raw);
  const parts = [raw];

  for (const [englishCity, aliases] of Object.entries(citySearchAliases)) {
    const matched = aliases.some((alias) => {
      return (
        normalizedRaw.includes(normalizeArabic(alias)) ||
        normalizedRawEn.includes(normalize(alias))
      );
    });

    if (matched) {
      parts.push(englishCity, ...aliases);
    }
  }

  return parts.join(' ');
}

function cityFieldMatches(value: string | null | undefined, translation: Translation | undefined, query: string) {
  if (!query) return true;
  return fieldMatches(citySearchText(value, translation), query);
}

function fieldMatches(value: string | null | undefined, query: string) {
  if (!query) return true;

  return (
    normalize(value).includes(normalize(query)) ||
    normalizeArabic(value).includes(normalizeArabic(query))
  );
}

function isGoodArabic(value: string | null | undefined) {
  const text = String(value || '').trim();
  return Boolean(text) && !/[�ØÃ]/.test(text);
}

function displayName(locale: Locale, university: any, translation?: Translation) {
  const translated = cleanName(translation?.name);
  const ar = cleanName(university.name_ar);
  const en = cleanName(university.name_en);
  const manualAr = manualArabicUniversityNames[university.university_id];

  if (locale === 'ar') {
    if (manualAr) return manualAr;
    if (isCleanArabicName(translated)) return translated;
    if (isCleanArabicName(ar)) return ar;
    return en || university.university_id;
  }

  return en || university.university_id;
}

function secondaryName(locale: Locale, university: any, translation?: Translation) {
  const en = cleanName(university.name_en);

  if (locale === 'ar') return en;

  return '';
}

function cityLabel(locale: Locale, value: string | null | undefined, translation?: Translation) {
  const translatedCity = cleanName(translation?.city);
  const raw = cleanName(value);

  if (locale === 'ar' && translatedCity && !/[�ØÃ]/.test(translatedCity)) {
    return translatedCity;
  }

  const key = normalize(raw);
  const match = cityNames[key];

  if (match) return match[locale];

  return raw || ui[locale].unknownCity;
}

function ownershipLabel(locale: Locale, value: string | null | undefined, translation?: Translation) {
  const translatedOwnership = cleanName(translation?.ownership);
  const raw = normalize(value);

  if (locale === 'ar' && translatedOwnership && !/[�ØÃ]/.test(translatedOwnership)) {
    return translatedOwnership;
  }

  if (raw.includes('private')) return ui[locale].private;
  if (raw.includes('public') || raw.includes('government')) return ui[locale].public;

  return value || ui[locale].unknownOwnership;
}

function displayCity(locale: Locale, university: any, translation?: Translation) {
  if (typeof cityLabel === 'function') {
    return cityLabel(locale, university.city, translation);
  }

  return translation?.city || university.city || ui[locale].unknownCity;
}

function displayOwnership(locale: Locale, university: any, translation?: Translation) {
  if (typeof ownershipLabel === 'function') {
    return ownershipLabel(locale, university.ownership, translation);
  }

  return translation?.ownership || university.ownership || ui[locale].unknownOwnership;
}

function qualityScore(university: any, translation?: Translation) {
  let score = 0;

  if (translation?.name || university.name_ar || university.name_en) score += 2;
  if (translation?.city || university.city) score += 2;
  if (translation?.ownership || university.ownership) score += 2;
  if (university.website) score += 2;
  if (university.rank_unirank_sudan) score += 2;
  if (university.rank_edurank_sudan) score += 2;
  if (university.rank_webometrics_sudan) score += 2;

  return score;
}

function bestRank(university: any) {
  const ranks = [
    Number(university.rank_edurank_sudan),
    Number(university.rank_webometrics_sudan),
    Number(university.rank_unirank_sudan),
  ].filter((rank) => Number.isFinite(rank) && rank > 0);

  return ranks.length ? Math.min(...ranks) : 999999;
}

function initials(name: string) {
  const clean = cleanName(name);

  if (/[\u0600-\u06FF]/.test(clean)) {
    return clean.replace(/\s+/g, '').slice(0, 2) || 'ج';
  }

  return (
    clean
      .split(' ')
      .filter(Boolean)
      .slice(0, 2)
      .map((word) => word[0])
      .join('')
      .toUpperCase() || 'SD'
  );
}

