function hasLatinLetters(value: string | null | undefined) {
  return /[A-Za-z]/.test(String(value || ''));
}

function isCleanArabicName(value: string | null | undefined) {
  const text = String(value || '').trim();
  return Boolean(text) && /[\u0600-\u06FF]/.test(text) && !hasLatinLetters(text) && !/[�ØÃ]/.test(text);
}

function cleanName(value: string | null | undefined) {
  return String(value || '')
    .replace(/\s+#\s*\d+.*$/g, '')
    .replace(/\s+Acceptance Rate.*$/gi, '')
    .replace(/\s+Statistics Rankings.*$/gi, '')
    .replace(/\s+Founded\s+\d{3,4}.*$/gi, '')
    .replace(/\s+Enrollment\s+.*$/gi, '')
    .replace(/\s+Read more.*$/gi, '')
    .replace(/\s+Male:Female.*$/gi, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function normalize(value: string | null | undefined) {
  return String(value || '').toLowerCase().replace(/\s+/g, ' ').trim();
}

function normalizeArabic(value: string | null | undefined) {
  return String(value || '')
    .replace(/[أإآ]/g, 'ا')
    .replace(/ى/g, 'ي')
    .replace(/ة/g, 'ه')
    .replace(/ؤ/g, 'و')
    .replace(/ئ/g, 'ي')
    .replace(/ـ/g, '')
    .toLowerCase()
    .replace(/\s+/g, ' ')
    .trim();
}

