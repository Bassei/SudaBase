export async function LocalizedUniversitiesPage({
  locale,
  searchParams,
}: {
  locale: Locale;
  searchParams?: { q?: string; city?: string; ownership?: string; website?: string };
}) {
  const label = ui[locale];
  const q = searchParams?.q || '';
  const city = searchParams?.city || '';
  const ownership = searchParams?.ownership || '';
  const website = searchParams?.website || '';

  const [{ data: universities }, { data: translations }] = await Promise.all([
    supabase.from('university_cards_enriched_public').select('*').limit(500),
    supabase.from('university_translations').select('*').eq('locale', locale),
  ]);

  const translationMap = new Map<string, Translation>();

  for (const translation of translations || []) {
    translationMap.set(translation.university_id, translation as Translation);
  }

  const all = (universities || []) as UniversityRecord[];

  const filtered = all
    .filter((university) => {
      const translation = translationMap.get(university.university_id);

      const searchText = [
        translation?.search_text,
        translation?.name,
        translation?.city,
        citySearchText(university.city, translation),
        translation?.ownership,
        university.name_en,
        university.name_ar,
        university.city,
        university.ownership,
        university.university_id,
      ].join(' ');

      return fieldMatches(searchText, q);
    })
    .filter((university) => {
      const translation = translationMap.get(university.university_id);
      return cityFieldMatches(university.city, translation, city);
    })
    .filter((university) => {
      const translation = translationMap.get(university.university_id);
      return fieldMatches([translation?.ownership, university.ownership].join(' '), ownership);
    })
    .filter((university) => website !== 'yes' || Boolean(university.website))
    .sort((a, b) => {
      const ta = translationMap.get(a.university_id);
      const tb = translationMap.get(b.university_id);

      const rankDiff = bestRank(a) - bestRank(b);
      if (rankDiff !== 0) return rankDiff;

      const qualityDiff = qualityScore(b, tb) - qualityScore(a, ta);
      if (qualityDiff !== 0) return qualityDiff;

      return displayName(locale, a, ta).localeCompare(displayName(locale, b, tb));
    })
    .slice(0, 24);

  return (
    <section dir={label.dir} className="mx-auto max-w-7xl space-y-8 px-4 py-12">
      <div className="rounded-[2rem] bg-gradient-to-br from-slate-950 to-emerald-950 p-8 text-white">
        <div className="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10">
          <GraduationCap className="h-8 w-8 text-emerald-300" />
        </div>

        <h1 className="mt-6 text-4xl font-black md:text-6xl">{label.title}</h1>

        <p className="mt-3 max-w-3xl leading-7 text-slate-200">
          {label.description}
        </p>

        <p className="mt-4 text-sm text-slate-300">
          {label.showing} {filtered.length} {label.of} {all.length} {label.records}
        </p>
      </div>

      <form className="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm">
        <div className="grid gap-4 md:grid-cols-4">
          <div className="relative md:col-span-2">
            <Search className="pointer-events-none absolute start-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" />
            <input
              name="q"
              defaultValue={q}
              placeholder={label.search}
              className="w-full rounded-2xl border border-slate-200 bg-white py-3 pe-4 ps-12 text-slate-950 outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-100"
            />
          </div>

          <input
            name="city"
            defaultValue={city}
            placeholder={label.city}
            className="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-100"
          />

          <input
            name="ownership"
            defaultValue={ownership}
            placeholder={label.ownership}
            className="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-100"
          />

          <select
            name="website"
            defaultValue={website}
            className="rounded-2xl border border-slate-200 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-100 md:col-span-1"
          >
            <option value="">{label.anyWebsite}</option>
            <option value="yes">{label.websiteOnly}</option>
          </select>

          <button
            className="rounded-2xl bg-slate-950 px-5 py-3 font-black text-white transition hover:bg-emerald-700 md:col-span-3"
            type="submit"
          >
            {label.apply}
          </button>
        </div>
      </form>

      <div className="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {filtered.map((university: UniversityRecord) => (
          <UniversityCard
            key={university.university_id}
            university={university}
            translation={translationMap.get(university.university_id)}
            locale={locale}
          />
        ))}
      </div>
    </section>
  );
}

export async function LocalizedUniversityDetailPage({
  locale,
  id,
}: {
  locale: Locale;
  id: string;
}) {
  const label = ui[locale];

  const [{ data: university }, { data: translation }, { data: programs }, { data: reviews }] =
    await Promise.all([
      supabase
        .from('university_cards_enriched_public')
        .select('*')
        .eq('university_id', id)
        .single(),
      supabase
        .from('university_translations')
        .select('*')
        .eq('university_id', id)
        .eq('locale', locale)
        .maybeSingle(),
      supabase
        .from('programs')
        .select('*')
        .eq('university_id', id)
        .order('program_or_faculty', { ascending: true }),
      supabase
        .from('student_reviews')
        .select('*')
        .eq('university_id', id)
        .eq('status', 'approved')
        .order('created_at', { ascending: false })
        .limit(20),
    ]);

  if (!university) notFound();

  const approvedReviews = reviews || [];

  const averageScore =
    approvedReviews.length > 0
      ? approvedReviews.reduce(
          (sum, review: any) => sum + Number(review.overall_score || 0),
          0
        ) / approvedReviews.length
      : null;

  const universityOption = [
    {
      university_id: university.university_id,
      name_en: university.name_en || university.university_id,
      name_ar: translation?.name || university.name_ar,
    },
  ];

  return (
    <section dir={label.dir} className="mx-auto max-w-7xl space-y-10 px-4 py-12">
      <div>
        <Link
          href={`/${locale}/universities`}
          className="text-sm font-bold text-emerald-700"
        >
          {label.back}
        </Link>

        <div className="mt-4 rounded-[2rem] bg-slate-950 p-8 text-white">
          <div className="flex flex-wrap items-start gap-5">
            <LogoMark university={university as UniversityRecord} name={displayName(locale, university, translation as Translation)} />

            <div>
              <h1 className="text-4xl font-black">
                {displayName(locale, university, translation as Translation)}
              </h1>

              {secondaryName(locale, university, translation as Translation) && (
                <p className="mt-2 text-xl text-slate-300" dir="ltr">
                  {secondaryName(locale, university, translation as Translation)}
                </p>
              )}
            </div>
          </div>

          <div className="mt-6 grid gap-4 md:grid-cols-4">
            <div>
              <p className="text-sm text-slate-400">{label.city}</p>
              <p className="font-bold">
                {cityLabel(locale, university.city, translation as Translation)}
              </p>
            </div>

            <div>
              <p className="text-sm text-slate-400">{label.ownership}</p>
              <p className="font-bold">
                {ownershipLabel(locale, university.ownership, translation as Translation)}
              </p>
            </div>

            <div>
              <p className="text-sm text-slate-400">{label.averageReview}</p>
              <p className="font-bold">
                {averageScore ? `${averageScore.toFixed(1)} / 5` : label.noReviews}
              </p>
            </div>
          </div>

          {university.website && (
            <a
              href={university.website}
              target="_blank"
              rel="noreferrer"
              className="mt-6 inline-flex rounded-2xl bg-white px-5 py-3 font-bold text-slate-950"
            >
              {label.visitWebsite}
            </a>
          )}
        </div>

        <OperationalStatusPanel data={university as UniversityRecord} locale={locale} />
      </div>

      <section className="space-y-4">
        <h2 className="text-3xl font-black">{label.programs}</h2>

        {!programs?.length ? (
          <div className="rounded-[2rem] border border-slate-200 bg-white p-6 text-slate-600 shadow-sm">
            {label.noPrograms}
          </div>
        ) : (
          <div className="grid gap-3 md:grid-cols-2">
            {programs.map((program: any) => (
              <div
                key={program.program_id}
                className="rounded-[2rem] border border-slate-200 bg-white p-5 shadow-sm"
              >
                <h3 className="font-bold">{program.program_or_faculty || '-'}</h3>
                <p className="mt-1 text-sm text-slate-600">{program.degree || '-'}</p>
              </div>
            ))}
          </div>
        )}
      </section>

      <section className="space-y-6">
        <div>
          <h2 className="text-3xl font-black">{label.reviewsTitle}</h2>
          <p className="mt-2 max-w-2xl text-slate-600">{label.reviewsDescription}</p>
        </div>

        <ReviewForm
          locale={locale}
          universities={universityOption}
          defaultUniversityId={university.university_id}
        />

        <div className="space-y-4">
          <h3 className="text-2xl font-bold">{label.approvedReviews}</h3>

          {!approvedReviews.length ? (
            <div className="rounded-[2rem] border border-slate-200 bg-white p-6 text-slate-600 shadow-sm">
              {label.noApprovedReviews}
            </div>
          ) : (
            <div className="grid gap-4 md:grid-cols-2">
              {approvedReviews.map((review: any) => (
                <article
                  key={review.review_id}
                  className="space-y-3 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm"
                >
                  <p className="text-3xl font-black text-emerald-700">
                    {Number(review.overall_score || 0).toFixed(1)} / 5
                  </p>

                  <p className="text-slate-700">{review.comment}</p>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    </section>
  );
}